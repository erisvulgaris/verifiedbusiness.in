// Prisma schema for VerifiedBusiness.in — production schema
// Covers: businesses, categories, reviews, subscriptions, users, ads, leads, tickets, notifications, invoices

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Geographic hierarchy ----------

model State {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String   @unique
  capital      String
  cityCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cities       City[]
  businesses   Business[]
  @@index([code])
}

model City {
  id        String   @id @default(cuid())
  name      String
  stateId   String
  state     State    @relation(fields: [stateId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  businesses Business[]
  localities Locality[]
  @@unique([name, stateId])
  @@index([stateId])
}

model Locality {
  id        String   @id @default(cuid())
  name      String
  cityId    String
  city      City     @relation(fields: [cityId], references: [id])
  pincode   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  businesses Business[]
  @@unique([name, cityId])
  @@index([cityId])
  @@index([pincode])
}

// ---------- Categories ----------

model Category {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  description   String
  icon          String   @default("Building2")
  listingCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  businesses Business[]
  @@index([slug])
}

// ---------- Businesses ----------

model Business {
  id              String   @id @default(cuid())
  name            String
  categorySlug    String
  category        Category @relation(fields: [categorySlug], references: [slug])
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  address         String
  localityId      String?
  locality        Locality? @relation(fields: [localityId], references: [id])
  cityId          String?
  city            City?     @relation(fields: [cityId], references: [id])
  stateCode       String?
  state           State?    @relation(fields: [stateCode], references: [code])
  pincode         String
  phone           String
  website         String?
  email           String?
  hours           String
  openNow         Boolean  @default(false)
  verified        Boolean  @default(false)
  paymentMethods  String   @default("[]")
  description     String   @default("")
  highlights      String   @default("[]")
  yearsActive     Int      @default(0)
  priceRange      String?
  photoCount      Int      @default(0)
  tags            String   @default("[]")
  logo            String?

  // Subscription
  subscriptionPlan      String   @default("free")
  subscriptionStatus    String   @default("active")
  subscriptionStart     DateTime?
  subscriptionEnd       DateTime?
  subscriptionAmount    Int      @default(0)
  subscriptionAutoRenew Boolean  @default(false)
  adCredit              Int      @default(0)

  // Claim
  claimedBy    String?
  claimStatus  String   @default("unclaimed")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviews    Review[]
  weeklyHours DayHours[]
  leads      Lead[]
  adCampaigns AdCampaign[]
  invoices   Invoice[]

  @@index([categorySlug])
  @@index([cityId])
  @@index([stateCode])
  @@index([pincode])
  @@index([verified])
  @@index([rating])
  @@index([subscriptionPlan])
  @@index([subscriptionStatus])
  @@index([claimStatus])
}

model DayHours {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  day        String
  open       String
  close      String
  closed     Boolean  @default(false)
  @@unique([businessId, day])
  @@index([businessId])
}

// ---------- Reviews ----------

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  author     String
  initials   String
  rating     Int
  date       String
  text       String
  helpful    Int      @default(0)
  status     String   @default("approved")
  flagReason String?
  response   String?
  respondedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([businessId])
  @@index([rating])
  @@index([status])
}

// ---------- Users & Auth ----------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  role      String   @default("viewer")
  status    String   @default("active")
  passwordHash String?
  image     String?
  emailVerified DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  accounts  Account[]
  sessions  Session[]
  ownedBusinesses String?
  tickets   SupportTicket[]
  notifications Notification[]
  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([userId])
}

// ---------- Ad Campaigns ----------

model AdCampaign {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  platform     String   @default("meta")
  status       String   @default("draft")
  headline     String
  description  String
  imageUrl     String?
  targetCity   String?
  targetRadius Int      @default(10)
  budget       Int      @default(0)
  spent        Int      @default(0)
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  leads        Int      @default(0)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([businessId])
  @@index([status])
}

// ---------- Leads ----------

model Lead {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  message     String
  status      String   @default("new")
  source      String   @default("website")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([businessId])
  @@index([status])
}

// ---------- Support Tickets ----------

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  businessId  String?
  subject     String
  fromEmail   String
  fromName    String
  category    String   @default("general")
  priority    String   @default("medium")
  status      String   @default("open")
  message     String
  response    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([status])
  @@index([priority])
  @@index([userId])
}

// ---------- Notifications ----------

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  type        String   @default("info")
  title       String
  description String
  read        Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())
  @@index([userId])
  @@index([read])
}

// ---------- Invoices ----------

model Invoice {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id])
  invoiceNumber String  @unique
  amount       Int
  plan         String
  period       String
  status       String   @default("paid")
  gstin        String?
  pdfUrl       String?
  createdAt    DateTime @default(now())
  @@index([businessId])
  @@index([status])
}

// ---------- Feature Flags ----------

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String
  enabled     Boolean  @default(false)
  category    String   @default("ui")
  updatedAt   DateTime @updatedAt
}
